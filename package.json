{
  "name": "obsidian-codex-excalidraw",
  "version": "0.4.5",
  "description": "Generate Excalidraw maps from Obsidian notes, selected files, or folders.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "release:check": "node scripts/verify-release.mjs",
    "test": "vitest run",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "excalidraw",
    "codex",
    "diagram",
    "canvas"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.12",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
